# ============================================================
# GLOBAL API SECRETS — TEMPLATE / REFERENCE FOR AI ASSISTANTS
# (no real secrets — safe to share with AI tools)
#
# WHERE THESE FILES LIVE:
#   - Real secrets (values filled in)  : ~/.config/api secrets/global.env
#                                         /Users/kasperdymek/.config/api secrets/global.env
#   - This template (empty, shareable) : ~/Projects/global.env.template
#                                         /Users/kasperdymek/Projects/global.env.template
#   NOTE: the secrets folder name has a space ("api secrets") — quote it in the shell.
#
# HOW TO USE A SECRET IN CODE:
#   - Do NOT open / read / print / commit the real secrets file. Load it at runtime
#     and reference values by name only; never hardcode a value:
#
#       # Python
#       from dotenv import load_dotenv; from pathlib import Path; import os
#       load_dotenv(Path.home() / ".config" / "api secrets" / "global.env")
#       key = os.environ["OPENAI_API_KEY"]
#
#       # Node.js
#       const os = require("os"), path = require("path");
#       require("dotenv").config({ path: path.join(os.homedir(), ".config", "api secrets", "global.env") });
#       const key = process.env.OPENAI_API_KEY;
#
# WHEN ADDING A NEW API:
#   - APPEND new keys to the END of both files as a "# --- ServiceName ---" block
#     with a short label; do NOT slot them into the category sections above.
#   - Add the same block to BOTH files; put the real value ONLY in the secrets file,
#     leaving it empty here. Use clear, conventional variable names.
#
# Sections: AI · Voice · Image/Video · VectorDB · Search · Maps/Geo · Finance ·
#           Poland-Gov · Databases · BaaS · Cloud · Storage · Payments · Email ·
#           SMS/Push · Auth · Productivity · Social · Monitoring · Scraping ·
#           DevOps · Defaults
# ============================================================


